NODE_ENV=production

# App ports
API_PORT=4000
WEB_PORT=3000

# Public URLs
WEB_ORIGIN=https://new.stmjournals.com
NEXT_PUBLIC_SITE_URL=https://new.stmjournals.com
NEXT_PUBLIC_API_BASE=https://apinew.stmjournals.com/api/v1

# Internal service URL (keep this as internal DNS, not public)
API_BASE=http://api:4000/api/v1

# Postgres
POSTGRES_USER=pub
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=pub
POSTGRES_PORT=55432
DATABASE_URL_INTERNAL=postgresql://pub:REPLACE_ME@postgres:5432/pub?schema=public
# Optional for host-side tooling only
DATABASE_URL=postgresql://pub:REPLACE_ME@localhost:55432/pub?schema=public

# Redis
REDIS_PORT=56379
REDIS_URL=redis://redis:6379

# Session/security
SESSION_SECRET=REPLACE_WITH_32_PLUS_CHAR_SECRET
STORAGE_CONFIG_ENCRYPTION_KEY=REPLACE_WITH_32_PLUS_CHAR_SECRET
COOKIE_SAMESITE=lax
SESSION_TTL_SECONDS=43200
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
RATE_LIMIT_AUTH_MAX=30

# MinIO / S3 (optional)
# Leave S3_* empty to disable upload/download signing routes.
# Keep MINIO_* only if you run the bundled minio service.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=REPLACE_ME
MINIO_API_PORT=59000
MINIO_CONSOLE_PORT=59001
S3_ENDPOINT=http://minio:9000
S3_BUCKET=publication
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY=REPLACE_ME
S3_SECRET_KEY=REPLACE_ME

# SMTP
SMTP_HOST=REPLACE_SMTP_HOST
SMTP_PORT=587
SMTP_USER=REPLACE_SMTP_USER
SMTP_PASS=REPLACE_SMTP_PASS
SMTP_FROM=no-reply@stmjournals.com

# Optional platform metadata (not required by app runtime)
SERVICE_URL_API=https://apinew.stmjournals.com
SERVICE_URL_WEB=https://new.stmjournals.com
SERVICE_FQDN_WEB=new.stmjournals.com
SERVICE_FQDN_API=apinew.stmjournals.com
