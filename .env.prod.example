NODE_ENV=production

# App
API_PORT=4000
WEB_PORT=3000
WEB_ORIGIN=https://your-domain.com
NEXT_PUBLIC_API_BASE=https://your-domain.com/api/v1
API_BASE=https://your-domain.com/api/v1

# Postgres
POSTGRES_USER=pub
POSTGRES_DB=pub
POSTGRES_PORT=55432
DATABASE_URL=postgresql://pub:REPLACE_ME@postgres:5432/pub

# Redis
REDIS_PORT=56379
REDIS_URL=redis://redis:6379

# MinIO
MINIO_API_PORT=59000
MINIO_CONSOLE_PORT=59001
S3_ENDPOINT=http://minio:9000
S3_BUCKET=publication
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# SMTP
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_FROM=no-reply@your-domain.com

# Images (pin by immutable tag/digest in real prod)
API_IMAGE=ghcr.io/example/publication-api:v1.0.0
WEB_IMAGE=ghcr.io/example/publication-web:v1.0.0
WORKER_IMAGE=ghcr.io/example/publication-worker:v1.0.0
