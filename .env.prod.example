NODE_ENV=production

# Public URLs
API_PORT=4000
WEB_PORT=3000
WEB_ORIGIN=https://your-domain.com
NEXT_PUBLIC_API_BASE=https://api.your-domain.com/api/v1
NEXT_PUBLIC_SITE_URL=https://your-domain.com
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# Internal API URL used by server-side Next.js in Docker network
API_BASE=http://api:4000/api/v1

# Postgres
POSTGRES_USER=pub
POSTGRES_DB=pub
POSTGRES_PORT=55432
DATABASE_URL_INTERNAL=postgresql://pub:REPLACE_ME@postgres:5432/pub?schema=public
# Optional: for host-side tools/scripts outside Docker network
DATABASE_URL=postgresql://pub:REPLACE_ME@localhost:55432/pub?schema=public

# Redis
REDIS_PORT=56379
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_API_PORT=59000
MINIO_CONSOLE_PORT=59001
S3_ENDPOINT=http://minio:9000
S3_BUCKET=publication
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# SMTP
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_FROM=no-reply@your-domain.com

# Security & session (optional overrides; defaults exist in code)
COOKIE_SAMESITE=lax
SESSION_TTL_SECONDS=43200
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
RATE_LIMIT_AUTH_MAX=30

# Optional platform metadata (not required by app runtime)
SERVICE_URL_API=https://api.your-domain.com
SERVICE_URL_WEB=https://your-domain.com
SERVICE_FQDN_WEB=your-domain.com
SERVICE_FQDN_API=api.your-domain.com
