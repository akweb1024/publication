generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JournalStatus {
  DRAFT
  LIVE
  ARCHIVED
}

enum ReviewModel {
  DOUBLE_BLIND
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum JournalRole {
  JOURNAL_ADMIN
  EDITOR_IN_CHIEF
  MANAGING_EDITOR
  SECTION_EDITOR
  ASSOCIATE_EDITOR
  COPYEDITOR
  PRODUCTION_EDITOR
  REVIEWER
  AUTHOR_SUPPORT
  SUBSCRIBER
}

enum PolicyContext {
  SUBMISSION
  REVIEW
  GENERAL
}

enum FileSetKind {
  SUBMISSION
  REVIEW
  PRODUCTION
  PUBLISHED
}

enum StoredFileRole {
  MANUSCRIPT
  SUPPLEMENT
  FIGURE
  RESPONSE_LETTER
  OTHER
}

enum StorageProvider {
  MINIO
  S3
  R2
  GCS
}

enum StorageTarget {
  LOCAL
  EXTERNAL
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  TRIAGE
  EDITOR_ASSIGNED
  UNDER_REVIEW
  REVISION_REQUESTED
  REVISED_SUBMITTED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum EditorAssignmentRole {
  HANDLING_EDITOR
  SECTION_EDITOR
}

enum ReviewAssignmentStatus {
  INVITED
  ACCEPTED
  DECLINED
  OVERDUE
  SUBMITTED
  CANCELLED
}

enum ReviewRecommendation {
  ACCEPT
  MINOR
  MAJOR
  REJECT
}

enum DecisionType {
  DESK_REJECT
  REVISE_MAJOR
  REVISE_MINOR
  ACCEPT
  REJECT
}

enum IssueStatus {
  PLANNED
  PUBLISHED
}

enum ArticleAccess {
  OPEN
  RESTRICTED
}

enum ArticleStatus {
  IN_PRESS
  PUBLISHED
  RETRACTED
  CORRECTED
  EOC
}

enum ArticleProductionStatus {
  NOT_STARTED
  IN_PRODUCTION
  AUTHOR_PROOF
  FINAL_QA
  READY_FOR_PUBLICATION
}

enum ProductionTaskType {
  COPYEDIT
  TYPESET
  AUTHOR_PROOF
  EDITOR_PROOF
  DOI_METADATA
  FINAL_QA
}

enum ProductionTaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum ProofRoundStatus {
  DRAFT
  SENT_TO_AUTHOR
  AUTHOR_APPROVED
  EDITOR_APPROVED
  CHANGES_REQUESTED
}

enum MessageDeliveryStatus {
  QUEUED
  SENT
  FAILED
}

enum NotificationEventStatus {
  PENDING
  QUEUED
  SENT
  FAILED
  SKIPPED
}

enum DataSyncRunStatus {
  SUCCESS
  FAILED
}

model Publisher {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  name          String
  defaultLocale String   @default("en")
  supportEmail  String

  journals Journal[]
}

model Journal {
  id                  String       @id @default(uuid())
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  publisherId         String
  slug                String
  title               String
  issnPrint           String?
  issnOnline          String?
  description         String?
  status              JournalStatus @default(DRAFT)
  reviewModel         ReviewModel   @default(DOUBLE_BLIND)
  submissionEmailFrom String?
  brandingJson        Json          @default("{}")
  timezone            String        @default("UTC")

  publisher          Publisher            @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  roleAssignments    JournalRoleAssignment[]
  policyDocuments    PolicyDocument[]
  fileSets           FileSet[]
  submissions        Submission[]
  volumes            Volume[]
  issues             Issue[]
  articles           Article[]
  productionTasks    ProductionTask[]
  proofRounds        ProofRound[]
  messageThreads     MessageThread[]
  emailTemplates     EmailTemplate[]
  notificationPreferences NotificationPreference[]
  notificationEvents NotificationEvent[]
  auditLogs          AuditLog[]
  submissionSequences SubmissionSequence[]
  requiredPolicyKeys String[] @default([])
  storageConfig      JournalStorageConfig?
  dataSyncConfig     JournalDataSyncConfig?
  dataSyncRuns       JournalDataSyncRun[]

  @@unique([slug])
  @@index([publisherId])
}

model JournalStorageConfig {
  id                 String          @id @default(uuid())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  journalId          String          @unique
  localPathPrefix    String          @default("system")
  externalPathPrefixes String[]      @default(["submissions", "uploads", "manuscripts", "exports"])
  defaultTarget      StorageTarget   @default(EXTERNAL)
  externalProvider   StorageProvider @default(MINIO)
  externalEndpoint   String?
  externalRegion     String?
  externalBucket     String?
  externalForcePathStyle Boolean     @default(true)
  encryptedSecretJson String?
  secretVersion      Int             @default(1)
  secretUpdatedAt    DateTime?

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)

  @@index([externalProvider])
}

model JournalDataSyncConfig {
  id                    String   @id @default(uuid())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  journalId             String   @unique
  enabled               Boolean  @default(false)
  autoSyncEnabled       Boolean  @default(false)
  encryptedDatabaseUrl  String?
  hasValidatedConnection Boolean @default(false)
  lastTestedAt          DateTime?
  lastSyncAt            DateTime?
  lastSyncStatus        DataSyncRunStatus?
  lastSyncMessage       String?

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)
}

model JournalDataSyncRun {
  id           String           @id @default(uuid())
  createdAt    DateTime         @default(now())
  journalId    String
  status       DataSyncRunStatus
  recordsSynced Int             @default(0)
  startedAt    DateTime         @default(now())
  finishedAt   DateTime?
  errorMessage String?
  metadataJson Json             @default("{}")

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)

  @@index([journalId, createdAt])
}

model User {
  id           String     @id @default(uuid())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  email        String     @unique
  passwordHash String
  name         String
  status       UserStatus @default(ACTIVE)
  orcidId      String?
  orcidAccessTokenRef String?
  mfaEnabled   Boolean    @default(false)
  mfaSecret    String?
  mfaEnabledAt DateTime?

  roleAssignments JournalRoleAssignment[]
  auditLogs       AuditLog[]
  submissions     Submission[] @relation("SubmissionSubmitter")
  editorAssignments EditorAssignment[]
  decisions       Decision[]
  messagesCreated MessageThread[] @relation("MessageThreadCreator")
  filesUploaded   StoredFile[]
  policyVersionsPublished PolicyVersion[]
  policyAcceptances PolicyAcceptance[]
  reviewAssignments ReviewAssignment[]
  emailTemplatesUpdated EmailTemplate[] @relation("EmailTemplateUpdatedBy")
  notificationPreferences NotificationPreference[]
  notificationEvents NotificationEvent[]
  productionTasksAssigned ProductionTask[] @relation("ProductionTaskAssignee")
  productionTasksCompleted ProductionTask[] @relation("ProductionTaskCompleter")
  proofRoundsAuthorApproved ProofRound[] @relation("ProofRoundAuthorApprover")
  proofRoundsEditorApproved ProofRound[] @relation("ProofRoundEditorApprover")
  proofAnnotationsCreated ProofAnnotation[]
}

model JournalRoleAssignment {
  id        String      @id @default(uuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  journalId String
  userId    String
  role      JournalRole
  subscriptionStartAt DateTime?
  subscriptionEndAt   DateTime?

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([journalId, userId, role])
  @@index([userId])
  @@index([role, subscriptionEndAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  occurredAt  DateTime @default(now())
  journalId   String?
  actorUserId String
  action      String
  entityType  String
  entityId    String
  ip          String?
  userAgent   String?
  metadataJson Json   @default("{}")

  journal Journal? @relation(fields: [journalId], references: [id], onDelete: SetNull)
  actor   User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([journalId, occurredAt])
  @@index([actorUserId, occurredAt])
}

model PolicyDocument {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  journalId  String
  key       String
  title     String

  journal  Journal         @relation(fields: [journalId], references: [id], onDelete: Cascade)
  versions PolicyVersion[]

  @@unique([journalId, key])
  @@index([journalId])
}

model PolicyVersion {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  policyDocumentId String
  versionNumber   Int
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  contentHtml     String
  changeNote      String?
  publishedByUserId String

  policyDocument PolicyDocument @relation(fields: [policyDocumentId], references: [id], onDelete: Cascade)
  publishedBy    User          @relation(fields: [publishedByUserId], references: [id], onDelete: Restrict)
  acceptances    PolicyAcceptance[]

  @@unique([policyDocumentId, versionNumber])
  @@index([policyDocumentId, effectiveFrom])
}

model PolicyAcceptance {
  id              String       @id @default(uuid())
  createdAt       DateTime     @default(now())
  policyVersionId String
  userId          String
  acceptedAt      DateTime     @default(now())
  context         PolicyContext

  policyVersion PolicyVersion @relation(fields: [policyVersionId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([policyVersionId, userId, context])
  @@index([userId, acceptedAt])
}

model SubmissionSequence {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  journalId  String
  year       Int
  nextNumber Int      @default(1)

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)

  @@unique([journalId, year])
}

model Submission {
  id              String          @id @default(uuid())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  journalId       String
  submitterUserId String
  trackingNumber  String?
  status          SubmissionStatus @default(DRAFT)
  manuscriptTitle String?
  abstractText    String?
  keywordsText    String[]        @default([])
  articleType     String?
  submittedAt     DateTime?
  decisionAt      DateTime?

  journal   Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  submitter User    @relation("SubmissionSubmitter", fields: [submitterUserId], references: [id], onDelete: Restrict)

  manuscriptVersions ManuscriptVersion[]
  contributors        SubmissionContributor[]
  editorAssignments   EditorAssignment[]
  reviewRounds        ReviewRound[]
  decisions           Decision[]
  messageThreads      MessageThread[]
  notificationEvents  NotificationEvent[]
  article             Article?

  @@unique([journalId, trackingNumber])
  @@index([journalId, status])
  @@index([submitterUserId, createdAt])
}

model ManuscriptVersion {
  id              String   @id @default(uuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  submissionId    String
  versionNumber   Int
  coverLetter     String?
  authorStatementJson Json @default("{}")
  fileSetId       String
  submittedAt     DateTime?

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fileSet    FileSet    @relation(fields: [fileSetId], references: [id], onDelete: Restrict)

  @@unique([submissionId, versionNumber])
  @@index([submissionId])
}

model FileSet {
  id        String     @id @default(uuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  journalId  String
  kind      FileSetKind
  storagePrefix String
  checksumManifestJson Json @default("{}")

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  files   StoredFile[]
  manuscriptVersions ManuscriptVersion[]
  reviews Review[]
}

model StoredFile {
  id            String        @id @default(uuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  fileSetId     String
  role          StoredFileRole @default(OTHER)
  originalName  String
  mimeType      String
  sizeBytes     Int
  sha256        String
  storageKey    String
  uploadedByUserId String

  fileSet    FileSet @relation(fields: [fileSetId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  publishedAssets PublishedAsset[]
  proofRounds ProofRound[]

  @@index([fileSetId])
  @@index([storageKey])
}

model SubmissionContributor {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  submissionId  String
  userId        String?
  displayName   String
  email         String
  affiliation   String?
  isCorresponding Boolean @default(false)
  orcidId       String?
  creditRoles   String[] @default([])
  isAnonymizedCopy Boolean @default(false)

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model EditorAssignment {
  id          String               @id @default(uuid())
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  submissionId String
  userId      String
  role        EditorAssignmentRole
  assignedAt  DateTime             @default(now())
  unassignedAt DateTime?

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([submissionId, assignedAt])
  @@index([userId, assignedAt])
}

model ReviewRound {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  submissionId String
  roundNumber Int
  startedAt   DateTime @default(now())
  endedAt     DateTime?

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  assignments ReviewAssignment[]

  @@unique([submissionId, roundNumber])
}

model ReviewAssignment {
  id            String                @id @default(uuid())
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  reviewRoundId String
  reviewerUserId String
  status        ReviewAssignmentStatus @default(INVITED)
  invitedAt     DateTime              @default(now())
  respondBy     DateTime?
  dueAt         DateTime?
  acceptedAt    DateTime?

  reviewRound ReviewRound @relation(fields: [reviewRoundId], references: [id], onDelete: Cascade)
  reviewer    User        @relation(fields: [reviewerUserId], references: [id], onDelete: Restrict)
  review      Review?

  @@unique([reviewRoundId, reviewerUserId])
  @@index([reviewerUserId, status])
}

model Review {
  id                 String               @id @default(uuid())
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  reviewAssignmentId String               @unique
  submittedAt        DateTime?
  recommendation     ReviewRecommendation?
  commentsToAuthor   String?
  commentsToEditor   String?
  attachmentsFileSetId String?

  reviewAssignment ReviewAssignment @relation(fields: [reviewAssignmentId], references: [id], onDelete: Cascade)
  attachmentsFileSet FileSet? @relation(fields: [attachmentsFileSetId], references: [id], onDelete: SetNull)
}

model Decision {
  id            String       @id @default(uuid())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  submissionId  String
  reviewRoundId String?
  type          DecisionType
  letterToAuthor String
  internalNote  String?
  decidedByUserId String
  decidedAt     DateTime     @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  decidedBy  User       @relation(fields: [decidedByUserId], references: [id], onDelete: Restrict)

  @@index([submissionId, decidedAt])
}

model MessageThread {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  journalId   String
  submissionId String?
  subject     String
  createdByUserId String

  journal   Journal     @relation(fields: [journalId], references: [id], onDelete: Cascade)
  submission Submission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  createdBy User        @relation("MessageThreadCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  messages  Message[]
  notificationEvents NotificationEvent[]

  @@index([journalId, createdAt])
  @@index([submissionId])
}

model Message {
  id          String               @id @default(uuid())
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  threadId    String
  fromUserId  String?
  toEmails    String[]             @default([])
  subjectOverride String?
  bodyHtml    String
  templateKey String?
  providerMessageId String?
  failedReason String?
  retryCount Int                   @default(0)
  sentAt      DateTime?
  deliveryStatus MessageDeliveryStatus @default(QUEUED)

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  notificationEvents NotificationEvent[]

  @@index([threadId, createdAt])
  @@index([templateKey])
  @@index([deliveryStatus, createdAt])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  journalId String
  key       String
  name      String
  description String?
  subject   String
  bodyHtml  String
  variablesJson Json @default("[]")
  active    Boolean @default(true)
  updatedByUserId String?

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  updatedBy User? @relation("EmailTemplateUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([journalId, key])
  @@index([journalId, active])
}

model NotificationPreference {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  journalId String
  userId    String
  eventKey  String
  emailEnabled Boolean @default(true)

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([journalId, userId, eventKey])
  @@index([userId, emailEnabled])
}

model NotificationEvent {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  journalId String
  submissionId String?
  articleId String?
  threadId String?
  messageId String?
  recipientUserId String?
  recipientEmail String
  eventKey String
  templateKey String?
  subject String
  status NotificationEventStatus @default(PENDING)
  payloadJson Json @default("{}")
  queuedAt DateTime?
  sentAt DateTime?
  failedAt DateTime?
  errorMessage String?

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  submission Submission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  article Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  thread MessageThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)
  message Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  recipientUser User? @relation(fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([journalId, createdAt])
  @@index([recipientEmail, createdAt])
  @@index([status, createdAt])
  @@index([eventKey, createdAt])
}

model Volume {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  journalId  String
  year       Int
  number     Int

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  issues  Issue[]

  @@unique([journalId, year, number])
  @@index([journalId])
}

model Issue {
  id              String      @id @default(uuid())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  journalId       String
  volumeId        String
  number          Int
  title           String?
  publicationDate DateTime?
  status          IssueStatus @default(PLANNED)

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  volume  Volume  @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  articles Article[]

  @@unique([journalId, volumeId, number])
  @@index([journalId, status])
}

model Article {
  id          String        @id @default(uuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  journalId   String
  submissionId String      @unique
  issueId     String?
  title       String
  abstractText String?
  keywordsText String[]    @default([])
  doi         String?
  pageStart   Int?
  pageEnd     Int?
  articleNumber String?
  access      ArticleAccess @default(OPEN)
  licenseKey  String?
  publishedAt DateTime?
  status      ArticleStatus @default(IN_PRESS)
  productionStatus ArticleProductionStatus @default(NOT_STARTED)

  journal    Journal    @relation(fields: [journalId], references: [id], onDelete: Cascade)
  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  issue      Issue?     @relation(fields: [issueId], references: [id], onDelete: SetNull)
  publishedAssets PublishedAsset[]
  notificationEvents NotificationEvent[]
  productionTasks ProductionTask[]
  proofRounds ProofRound[]

  @@index([journalId, status])
  @@index([journalId, productionStatus])
  @@index([issueId])
}

model ProductionTask {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  journalId String
  articleId String
  type      ProductionTaskType
  status    ProductionTaskStatus @default(TODO)
  title     String
  notes     String?
  assignedToUserId String?
  dueAt     DateTime?
  startedAt DateTime?
  completedAt DateTime?
  completedByUserId String?
  metadataJson Json @default("{}")

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  assignedTo User? @relation("ProductionTaskAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  completedBy User? @relation("ProductionTaskCompleter", fields: [completedByUserId], references: [id], onDelete: SetNull)

  @@index([journalId, status])
  @@index([articleId, type])
  @@index([assignedToUserId, status])
}

model ProofRound {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  journalId String
  articleId String
  roundNumber Int
  status    ProofRoundStatus @default(DRAFT)
  proofFileId String?
  authorApprovedAt DateTime?
  authorApprovedByUserId String?
  editorApprovedAt DateTime?
  editorApprovedByUserId String?
  notes String?

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  proofFile StoredFile? @relation(fields: [proofFileId], references: [id], onDelete: SetNull)
  authorApprovedBy User? @relation("ProofRoundAuthorApprover", fields: [authorApprovedByUserId], references: [id], onDelete: SetNull)
  editorApprovedBy User? @relation("ProofRoundEditorApprover", fields: [editorApprovedByUserId], references: [id], onDelete: SetNull)
  annotations ProofAnnotation[]

  @@unique([articleId, roundNumber])
  @@index([journalId, status])
}

model ProofAnnotation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  proofRoundId String
  createdByUserId String
  pageNumber Int?
  anchorText String?
  commentText String
  resolvedAt DateTime?

  proofRound ProofRound @relation(fields: [proofRoundId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([proofRoundId, createdAt])
}

model PublishedAsset {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  articleId   String
  pdfFileId   String
  versionLabel String
  publishedAt DateTime @default(now())

  article Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  pdfFile StoredFile @relation(fields: [pdfFileId], references: [id], onDelete: Restrict)

  @@index([articleId, publishedAt])
}
